{
  "manifest_version": 3,
  "name": "Feed-The-Cat",
  "version": "1.2.0",
  "description": "A productivity cat. happy when you work, sad when you dont.",
  "permissions": ["storage", "tabs", "alarms", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}